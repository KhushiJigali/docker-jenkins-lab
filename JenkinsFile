pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                git 'https://github.com/KhushiJigali/docker-jenkins-lab.git'
            }
        }
       stage('Welcome') {
    steps {
        echo 'Hello! Jenkins has successfully pulled the code.'
        sh 'python3 app.py' // Use 'sh' and 'python3' for Linux
    }
}
    }
}
