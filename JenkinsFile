pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                git 'https://github.com/KhushiJigali/docker-jenkins-lab.git'
            }
        }
        stage('Welcome') {
            steps {
                echo 'Hello! Jenkins has successfully pulled the code.'
                // Change 'bat' to 'sh' if you are on Linux/Mac
                bat 'python app.py' 
            }
        }
    }
}
